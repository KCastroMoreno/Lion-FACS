def _run_export(node_field, start_field, end_field):
    node = cmds.textField(node_field, q=True, text=True).strip().rstrip(".")
    if not node:
        cmds.warning("Please enter a source control node name.")
        return

    start_str = cmds.textField(start_field, q=True, text=True).strip()
    end_str   = cmds.textField(end_field,   q=True, text=True).strip()

    frame_start = None
    frame_end   = None

    if start_str and end_str:
        try:
            frame_start = float(start_str)
            frame_end   = float(end_str)
        except ValueError:
            cmds.warning("Frame range must be numbers. Leave both blank to export all keys.")
            return
    elif start_str or end_str:
        cmds.warning("Please fill in BOTH Start and End frames, or leave both blank to export all.")
        return

    export_face_anim_node(node=node, frame_start=frame_start, frame_end=frame_end)


def _run_import(node_field, offset_field, pad_field, zero_pad_cb):
    node = cmds.textField(node_field, q=True, text=True).strip().rstrip(".")
    if not node:
        cmds.warning("Please enter a target control node name.")
        return

    offset_str = cmds.textField(offset_field, q=True, text=True).strip()
    pad_str    = cmds.textField(pad_field,    q=True, text=True).strip()
    do_pad     = cmds.checkBox(zero_pad_cb, q=True, value=True)

    import_offset = None
    if offset_str:
        try:
            import_offset = float(offset_str)
        except ValueError:
            cmds.warning("Import start frame must be a number.")
            return

    pad_frames = 5
    if pad_str:
        try:
            pad_frames = int(pad_str)
        except ValueError:
            cmds.warning("Pad frames must be a whole number.")
            return

    import_face_anim_node(
        node=node,
        import_offset=import_offset,
        zero_pad=do_pad,
        pad_frames=pad_frames
    )


def launch_ui():
    win = "faceAnimTransferWin"
    if cmds.window(win, exists=True):
        cmds.deleteUI(win)

    cmds.window(win, title="Face Anim Transfer", widthHeight=(400, 440))
    cmds.columnLayout(adjustableColumn=True, rowSpacing=6, columnOffset=("both", 14))
    cmds.separator(height=12)

    # ── EXPORT ──
    cmds.text(label="EXPORT  -  run in source scene", align="left", font="boldLabelFont")
    cmds.separator(height=4, style="none")
    cmds.text(label="Source control node:", align="left")
    export_node_field = cmds.textField(placeholderText="e.g.  lion10:face_main_ctrl")
    cmds.separator(height=4, style="none")
    cmds.text(label="Frame range  (leave blank = export all keys):", align="left")
    cmds.rowLayout(numberOfColumns=3, columnWidth3=(150, 24, 150), adjustableColumn=2)
    export_start_field = cmds.textField(placeholderText="Start  e.g. 100")
    cmds.text(label="  to  ", align="center")
    export_end_field   = cmds.textField(placeholderText="End  e.g. 300")
    cmds.setParent("..")
    cmds.separator(height=6, style="none")
    cmds.button(
        label="Export Animation...", height=38,
        backgroundColor=(0.25, 0.55, 0.35),
        command=lambda x: _run_export(export_node_field, export_start_field, export_end_field)
    )

    cmds.separator(height=18)

    # ── IMPORT ──
    cmds.text(label="IMPORT  -  run in target scene", align="left", font="boldLabelFont")
    cmds.separator(height=4, style="none")
    cmds.text(label="Target control node:", align="left")
    import_node_field = cmds.textField(placeholderText="e.g.  lion:face_main_ctrl")
    cmds.separator(height=4, style="none")
    cmds.text(label="Import start frame  (leave blank = keep original frames):", align="left")
    import_offset_field = cmds.textField(placeholderText="e.g.  500")
    cmds.separator(height=4, style="none")
    zero_pad_cb = cmds.checkBox(label="Add zero padding keys before and after anim", value=True)
    cmds.separator(height=2, style="none")
    cmds.text(label="Padding frames (before / after):", align="left")
    import_pad_field = cmds.textField(text="5")
    cmds.separator(height=6, style="none")
    cmds.button(
        label="Import Animation...", height=38,
        backgroundColor=(0.25, 0.40, 0.65),
        command=lambda x: _run_import(import_node_field, import_offset_field, import_pad_field, zero_pad_cb)
    )

    cmds.separator(height=18)

    # ── RESET ──
    cmds.text(label="RESET  -  clear all anim and zero controls", align="left", font="boldLabelFont")
    cmds.separator(height=4, style="none")
    cmds.text(label="Control node to reset:", align="left")
    reset_node_field = cmds.textField(placeholderText="e.g.  lion:face_main_ctrl")
    cmds.separator(height=6, style="none")
    cmds.button(
        label="Clear All Anim + Zero Controls", height=38,
        backgroundColor=(0.55, 0.25, 0.25),
        command=lambda x: _run_reset(reset_node_field)
    )

    cmds.separator(height=12)
    cmds.showWindow(win)


def _run_reset(node_field):
    node = cmds.textField(node_field, q=True, text=True).strip().rstrip(".")
    if not node:
        cmds.warning("Please enter a control node name to reset.")
        return

    confirm = cmds.confirmDialog(
        title="Clear All Animation",
        message="This will delete ALL keyframes and set all controls to 0 on:\n\n{}\n\nThis cannot be undone. Continue?".format(node),
        button=["Yes, Clear Everything", "Cancel"],
        defaultButton="Cancel",
        cancelButton="Cancel",
        dismissString="Cancel"
    )
    if confirm != "Yes, Clear Everything":
        return

    reset_face_anim(node)


def reset_face_anim(node):
    node = node.strip().rstrip(".")
    if not cmds.objExists(node):
        cmds.warning("Node not found: {}".format(node))
        return

    cleared = []
    zeroed  = []
    skipped = []

    for attr in FACE_ATTRS:
        plug = "{}.{}".format(node, attr)
        if not cmds.objExists(plug):
            continue
        if cmds.getAttr(plug, lock=True):
            skipped.append(attr)
            continue
        try:
            cmds.cutKey(plug, clear=True)
            cleared.append(attr)
        except Exception:
            pass
        try:
            cmds.setAttr(plug, 0)
            zeroed.append(attr)
        except Exception:
            pass

    print("\n*** Reset complete on {}".format(node))
    print("  Keys cleared : {}".format(len(cleared)))
    print("  Zeroed       : {}".format(len(zeroed)))
    if skipped:
        print("  Skipped (locked) : {}".format(", ".join(skipped)))


launch_ui()
