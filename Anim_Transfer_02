# ─────────────────────────────────────────────────────────────
# HELPERS
# ─────────────────────────────────────────────────────────────

def _get_curve_data(node, attr, frame_start=None, frame_end=None):
    plug = "{}.{}".format(node, attr)
    if not cmds.objExists(plug):
        return None

    anim_curves = cmds.listConnections(plug, type="animCurve", source=True) or []
    if not anim_curves:
        return None

    curve = anim_curves[0]

    if frame_start is not None and frame_end is not None:
        keyframes = cmds.keyframe(
            curve, query=True,
            time=(frame_start, frame_end),
            timeChange=True, valueChange=True
        )
    else:
        keyframes = cmds.keyframe(curve, query=True, timeChange=True, valueChange=True)

    if not keyframes:
        return None

    times  = keyframes[0::2]
    values = keyframes[1::2]

    time_range    = (times[0], times[-1])
    in_tan_types  = cmds.keyTangent(curve, q=True, time=time_range, inTangentType=True)  or []
    out_tan_types = cmds.keyTangent(curve, q=True, time=time_range, outTangentType=True) or []
    in_angles     = cmds.keyTangent(curve, q=True, time=time_range, inAngle=True)        or []
    out_angles    = cmds.keyTangent(curve, q=True, time=time_range, outAngle=True)       or []
    in_weights    = cmds.keyTangent(curve, q=True, time=time_range, inWeight=True)       or []
    out_weights   = cmds.keyTangent(curve, q=True, time=time_range, outWeight=True)      or []

    return {
        "times":         times,
        "values":        values,
        "in_tan_types":  in_tan_types,
        "out_tan_types": out_tan_types,
        "in_angles":     in_angles,
        "out_angles":    out_angles,
        "in_weights":    in_weights,
        "out_weights":   out_weights,
        "pre_infinity":  (cmds.setInfinity(curve, q=True, preInfinite=True)  or ["constant"])[0],
        "post_infinity": (cmds.setInfinity(curve, q=True, postInfinite=True) or ["constant"])[0],
    }


# ─────────────────────────────────────────────────────────────
# EXPORT
# ─────────────────────────────────────────────────────────────

def export_face_anim_node(node, file_path=None, frame_start=None, frame_end=None):
    node = node.strip().rstrip(".")
    if not cmds.objExists(node):
        cmds.warning("Node not found: {}".format(node))
        return

    if file_path is None:
        result = cmds.fileDialog2(
            fileFilter="JSON Files (*.json);;All Files (*.*)",
            dialogStyle=2, fileMode=0,
            caption="Save Face Animation"
        )
        if not result:
            return
        file_path = result[0]

    anim_data   = {}
    static_data = {}
    not_found   = []

    for attr in FACE_ATTRS:
        plug = "{}.{}".format(node, attr)
        if not cmds.objExists(plug):
            not_found.append(attr)
            continue
        data = _get_curve_data(node, attr, frame_start, frame_end)
        if data:
            anim_data[attr] = data
        else:
            try:
                val = cmds.getAttr(plug)
                static_data[attr] = val
            except Exception:
                pass

    with open(file_path, "w") as f:
        json.dump({
            "node":        node,
            "frame_start": frame_start,
            "frame_end":   frame_end,
            "attrs":       anim_data,
            "static":      static_data
        }, f, indent=2)

    range_str = "{} - {}".format(int(frame_start), int(frame_end)) if frame_start is not None else "all frames"
    print("\n*** Face anim exported -> {}".format(file_path))
    print("  Frame range  : {}".format(range_str))
    print("  Keyed attrs  : {}".format(len(anim_data)))
    print("  Static attrs : {}".format(len(static_data)))
    if not_found:
        print("  Not on node  : {}".format(", ".join(not_found)))


# ─────────────────────────────────────────────────────────────
# IMPORT
# ─────────────────────────────────────────────────────────────

def import_face_anim_node(node, file_path=None, import_offset=None,
                          zero_pad=True, pad_frames=5):
    node = node.strip().rstrip(".")
    if not cmds.objExists(node):
        cmds.warning("Node not found: {}".format(node))
        return

    if file_path is None:
        result = cmds.fileDialog2(
            fileFilter="JSON Files (*.json);;All Files (*.*)",
            dialogStyle=2, fileMode=1,
            caption="Load Face Animation"
        )
        if not result:
            return
        file_path = result[0]

    with open(file_path, "r") as f:
        saved = json.load(f)

    anim_data   = saved.get("attrs",  {})
    static_data = saved.get("static", {})

    # Compute time offset so animation starts at import_offset
    all_times = []
    for data in anim_data.values():
        all_times.extend(data.get("times", []))

    if all_times and import_offset is not None:
        original_start = min(all_times)
        time_offset    = import_offset - original_start
    else:
        time_offset = 0

    applied        = []
    applied_static = []
    skipped        = []

    # Work out the full imported time range so we can clear only that window
    if all_times:
        import_start = min(all_times) + time_offset
        import_end   = max(all_times) + time_offset
        # Also account for the zero pad frames when clearing
        clear_start  = import_start - pad_frames - 1  if zero_pad else import_start
        clear_end    = import_end   + pad_frames + 1  if zero_pad else import_end
    else:
        clear_start = clear_end = None

    # ── Keyed animation ──
    for attr, data in anim_data.items():
        plug = "{}.{}".format(node, attr)
        if not cmds.objExists(plug):
            skipped.append("{} (not found)".format(attr))
            continue
        if cmds.getAttr(plug, lock=True):
            skipped.append("{} (locked)".format(attr))
            continue

        # Clear only keys within the incoming range — leaves other anims untouched
        if clear_start is not None:
            cmds.cutKey(plug, time=(clear_start, clear_end), clear=True)

        times         = data["times"]
        values        = data["values"]
        in_tan_types  = data.get("in_tan_types",  [])
        out_tan_types = data.get("out_tan_types", [])
        in_angles     = data.get("in_angles",     [])
        out_angles    = data.get("out_angles",    [])
        in_weights    = data.get("in_weights",    [])
        out_weights   = data.get("out_weights",   [])
        pre_inf       = data.get("pre_infinity",  "constant")
        post_inf      = data.get("post_infinity", "constant")

        for i, (t, v) in enumerate(zip(times, values)):
            new_t = t + time_offset
            cmds.setKeyframe(plug, time=new_t, value=v)

            tan_kw = {"time": (new_t, new_t)}
            if i < len(in_tan_types):  tan_kw["inTangentType"]  = in_tan_types[i]
            if i < len(out_tan_types): tan_kw["outTangentType"] = out_tan_types[i]
            cmds.keyTangent(plug, **tan_kw)

            w_kw = {"time": (new_t, new_t)}
            if i < len(in_angles):   w_kw["inAngle"]   = in_angles[i]
            if i < len(out_angles):  w_kw["outAngle"]  = out_angles[i]
            if i < len(in_weights):  w_kw["inWeight"]  = in_weights[i]
            if i < len(out_weights): w_kw["outWeight"] = out_weights[i]
            if len(w_kw) > 1:
                try:
                    cmds.keyTangent(plug, **w_kw)
                except Exception:
                    pass

        anim_curves = cmds.listConnections(plug, type="animCurve", source=True) or []
        if anim_curves:
            cmds.setInfinity(anim_curves[0], preInfinite=pre_inf, postInfinite=post_inf)

        applied.append(attr)

    # ── Static values ──
    for attr, val in static_data.items():
        plug = "{}.{}".format(node, attr)
        if not cmds.objExists(plug):
            skipped.append("{} (not found)".format(attr))
            continue
        if cmds.getAttr(plug, lock=True):
            skipped.append("{} (locked)".format(attr))
            continue
        try:
            # Clear any existing keys in the target range before applying static value
            if clear_start is not None:
                cmds.cutKey(plug, time=(clear_start, clear_end), clear=True)
            cmds.setAttr(plug, val)
            applied_static.append(attr)
        except Exception as e:
            skipped.append("{} (setAttr failed: {})".format(attr, e))

    # ── Zero padding ──
    if zero_pad and all_times:
        actual_start = min(all_times) + time_offset
        actual_end   = max(all_times) + time_offset
        pre_frame    = actual_start - pad_frames
        post_frame   = actual_end   + pad_frames

        for attr in FACE_ATTRS:
            plug = "{}.{}".format(node, attr)
            if not cmds.objExists(plug) or cmds.getAttr(plug, lock=True):
                continue
            try:
                # Zero keys before and after
                cmds.setKeyframe(plug, time=pre_frame,  value=0)
                cmds.setKeyframe(plug, time=post_frame, value=0)

                # Lock-in first and last frame of the anim
                if attr in anim_data:
                    cmds.setKeyframe(plug, time=actual_start, value=anim_data[attr]["values"][0])
                    cmds.setKeyframe(plug, time=actual_end,   value=anim_data[attr]["values"][-1])
                elif attr in static_data:
                    cmds.setKeyframe(plug, time=actual_start, value=static_data[attr])
                    cmds.setKeyframe(plug, time=actual_end,   value=static_data[attr])
            except Exception:
                pass

        print("  Zero padding   : frame {} (pre)  |  frame {} (post)  [{}f pad]".format(
            int(pre_frame), int(post_frame), pad_frames))

    print("\n*** Face anim imported from {}".format(file_path))
    if all_times:
        print("  Anim range     : {} - {}".format(
            int(min(all_times) + time_offset),
            int(max(all_times) + time_offset)))
    print("  Keyed applied  : {}".format(len(applied)))
    print("  Static applied : {}".format(len(applied_static)))
    if skipped:
        print("  Skipped        : {}".format(", ".join(skipped)))


