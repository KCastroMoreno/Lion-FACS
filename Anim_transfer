def _get_node(namespace="lion"):
    """Return the full node name, auto-detecting namespace if needed."""
    # Strip any trailing colons from namespace input
    namespace = namespace.strip().rstrip(":")

    # Try exact namespace provided
    if namespace:
        with_ns = "{}:face_main_ctrl".format(namespace)
        if cmds.objExists(with_ns):
            return with_ns

    # Try without namespace
    if cmds.objExists("face_main_ctrl"):
        return "face_main_ctrl"

    # Auto-detect: search all nodes ending in face_main_ctrl
    matches = cmds.ls("*:face_main_ctrl") or []
    if matches:
        print("  Auto-detected node: {}".format(matches[0]))
        return matches[0]

    cmds.warning("Could not find face_main_ctrl in the scene.")
    return None


def _get_curve_data(node, attr):
    """Return keyframe data dict for node.attr, or None if no keys."""
    plug = "{}.{}".format(node, attr)
    if not cmds.objExists(plug):
        return None

    anim_curves = cmds.listConnections(plug, type="animCurve", source=True) or []
    if not anim_curves:
        return None

    curve = anim_curves[0]
    keyframes = cmds.keyframe(curve, query=True, timeChange=True, valueChange=True)
    if not keyframes:
        return None

    times  = keyframes[0::2]
    values = keyframes[1::2]

    return {
        "times":         times,
        "values":        values,
        "in_tan_types":  cmds.keyTangent(curve, q=True, inTangentType=True)  or [],
        "out_tan_types": cmds.keyTangent(curve, q=True, outTangentType=True) or [],
        "in_angles":     cmds.keyTangent(curve, q=True, inAngle=True)        or [],
        "out_angles":    cmds.keyTangent(curve, q=True, outAngle=True)       or [],
        "in_weights":    cmds.keyTangent(curve, q=True, inWeight=True)       or [],
        "out_weights":   cmds.keyTangent(curve, q=True, outWeight=True)      or [],
        "pre_infinity":  (cmds.setInfinity(curve, q=True, preInfinite=True)  or ["constant"])[0],
        "post_infinity": (cmds.setInfinity(curve, q=True, postInfinite=True) or ["constant"])[0],
    }


