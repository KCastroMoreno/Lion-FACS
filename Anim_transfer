# EXPORT
# ─────────────────────────────────────────────────────────────

def export_face_anim(file_path=None, namespace="lion"):
    """
    Export all facial attribute keyframes from face_main_ctrl to a JSON file.

    Args:
        file_path : output .json path. Opens dialog if None.
        namespace : rig namespace (default 'lion').
    """
    node = _get_node(namespace)
    if not node:
        return

    if file_path is None:
        result = cmds.fileDialog2(
            fileFilter="JSON Files (*.json);;All Files (*.*)",
            dialogStyle=2, fileMode=0,
            caption="Save Face Animation"
        )
        if not result:
            return
        file_path = result[0]

    anim_data   = {}
    no_keys     = []
    not_found   = []

    for attr in FACE_ATTRS:
        plug = "{}.{}".format(node, attr)
        if not cmds.objExists(plug):
            not_found.append(attr)
            continue
        data = _get_curve_data(node, attr)
        if data:
            anim_data[attr] = data
        else:
            no_keys.append(attr)

    with open(file_path, "w") as f:
        json.dump({"node": node, "attrs": anim_data}, f, indent=2)

    print("\n✔ Face anim exported → {}".format(file_path))
    print("  Keyed attrs   : {}".format(len(anim_data)))
    print("  No keys (ok)  : {}".format(len(no_keys)))
    if not_found:
        print("  Not on node   : {}".format(", ".join(not_found)))


